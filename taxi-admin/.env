NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# Database (lokaal)
DATABASE_URL=postgresql://taxiboek:taxiboek_password@localhost:5432/taxiboek

# JWT (dummy waardes voor test)
JWT_SECRET=test-secret-key-for-development-only
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-secret-for-development-only

# Redis (lokaal)
REDIS_URL=redis://localhost:6379

# Stripe - UITGESCHAKELD voor test
# Alle subscription calls worden gemockt
STRIPE_SECRET_KEY=sk_test_disabled_in_dev_mode
STRIPE_WEBHOOK_SECRET=whsec_disabled_in_dev_mode
STRIPE_PRICE_BASIC=price_test_basic
STRIPE_PRICE_PRO=price_test_pro

# OpenAI - UITGESCHAKELD voor test
# Receipts worden met mock data verwerkt
OPENAI_API_KEY=sk-test-disabled-in-dev-mode

# OAuth - placeholders (geen echte APIs beschikbaar)
UBER_CLIENT_ID=dev_placeholder
UBER_CLIENT_SECRET=dev_placeholder
UBER_REDIRECT_URI=http://localhost:3000/api/v1/platform-integrations/uber/callback

BOLT_CLIENT_ID=dev_placeholder
BOLT_CLIENT_SECRET=dev_placeholder
BOLT_REDIRECT_URI=http://localhost:3000/api/v1/platform-integrations/bolt/callback

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads
