NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://taxiboek:taxiboek_password@localhost:5432/taxiboek

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-too-in-production

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_BASIC=price_basic_id
STRIPE_PRICE_PRO=price_pro_id

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# OAuth (placeholder - Uber/Bolt don't have public driver APIs)
UBER_CLIENT_ID=placeholder
UBER_CLIENT_SECRET=placeholder
UBER_REDIRECT_URI=http://localhost:3000/api/v1/platform-integrations/uber/callback

BOLT_CLIENT_ID=placeholder
BOLT_CLIENT_SECRET=placeholder
BOLT_REDIRECT_URI=http://localhost:3000/api/v1/platform-integrations/bolt/callback

# File uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads
